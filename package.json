{
  "name": "artemiswatch.org",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i src/input.css -o dist/style.css --minify",
    "build:copy": "node build.mjs",
    "build": "npm run build:css && npm run build:copy",
    "dev:css": "tailwindcss -i src/input.css -o dist/style.css --watch",
    "dev:serve": "browser-sync start --config browser-sync.config.cjs",
    "dev": "concurrently -k \"npm:dev:css\" \"npm:dev:serve\""
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^3"
  }
}
